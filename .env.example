# KARAKURI runtime (copy to .env)

# Project root override (default: directory containing STOP file)
# KARAKURI_ROOT=/home/you/karakuri

# Watchdog
KARAKURI_TICK_SECONDS=5
KARAKURI_MAX_FIXES_PER_HOUR=12

# Web research (allowlist enforced in core/permissions.yaml)
SEARXNG_URL=http://127.0.0.1:8080
WEB_CACHE_TTL_HOURS=168

# Robot (ROS 2, later phases)
ROS_DOMAIN_ID=42
ROBOT_WORKSPACE=/home/you/karakuri/robot/ws

# Rename project display name without renaming package yet
KARAKURI_DISPLAY_NAME=KARAKURI
